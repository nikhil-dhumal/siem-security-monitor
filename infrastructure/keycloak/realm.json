{
  "realm": "siem2",
  "displayName": "SIEM Security Monitor",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "clients": [
    {
      "clientId": "siem-frontend",
      "name": "SIEM Frontend",
      "description": "Frontend client for SIEM",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "siem-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "standardFlowEnabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "attributes": {
        "saml.assertion.signature": "false",
        "saml.multivalued.roles": "false",
        "saml.force.post.binding": "false",
        "saml.encrypt": "false",
        "saml.server.signature": "false",
        "saml.server.signature.keyinfo.ext": "false",
        "exclude.session.state.from.auth.response": "false",
        "saml_force_name_id_format": "false",
        "saml.client.signature": "false",
        "tls.client.certificate.bound.access.tokens": "false",
        "saml.authnstatement": "false",
        "display.on.consent.screen": "false",
        "saml.onetimeuse.condition": "false",
        "pkce.code.challenge.method": "S256"
      },
      "authenticationFlowBindingOverrides": {},
      "fullScopeAllowed": true,
      "nodeReRegistrationTimeout": -1,
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "foo",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "web-origins",
        "role_list",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://localhost:5175",
        "http://localhost:5176",
        "http://localhost:5177",
        "http://localhost:5178",
        "http://localhost:5179",
        "http://localhost:5180"
      ],
      "redirectUris": [
        "http://localhost:5173",
        "http://localhost:5173/",
        "http://localhost:5173/*",
        "http://localhost:5174",
        "http://localhost:5174/",
        "http://localhost:5174/*",
        "http://localhost:5175",
        "http://localhost:5175/",
        "http://localhost:5175/*",
        "http://localhost:5176",
        "http://localhost:5176/",
        "http://localhost:5176/*",
        "http://localhost:5177",
        "http://localhost:5177/",
        "http://localhost:5177/*",
        "http://localhost:5178",
        "http://localhost:5178/",
        "http://localhost:5178/*",
        "http://localhost:5179",
        "http://localhost:5179/",
        "http://localhost:5179/*",
        "http://localhost:5180",
        "http://localhost:5180/",
        "http://localhost:5180/*"
      ]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "view",
        "description": "Viewer role for dashboard, history, analytics",
        "composite": false,
        "clientRole": false,
        "containerId": "siem"
      },
      {
        "name": "admin",
        "description": "Admin role for dashboard, analytics, history, rules",
        "composite": false,
        "clientRole": false,
        "containerId": "siem"
      },
      {
        "name": "simulator",
        "description": "Simulator role for simulation",
        "composite": false,
        "clientRole": false,
        "containerId": "siem"
      }
    ]
  },
  "users": [
    {
      "username": "viewer",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Viewer",
      "lastName": "User",
      "email": "viewer@siem.com",
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": [
        "view"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "email": "admin@siem.com",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "simulator",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Simulator",
      "lastName": "User",
      "email": "simulator@siem.com",
      "credentials": [
        {
          "type": "password",
          "value": "simulator",
          "temporary": false
        }
      ],
      "realmRoles": [
        "simulator"
      ]
    }
  ]
}